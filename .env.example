# ---------------------------------------------------------------------------
# veent-crm environment (see sales-crm.md §Ops/security). Copy to .env and fill.
# NO external-system references. All secrets live here (compose .env in prod).
# In v0 everything is a stub: the app boots with only DATABASE_URL set (or even without).
# ---------------------------------------------------------------------------

# Postgres (self-managed on the droplet; compose-internal only in prod)
DATABASE_URL="postgres://crm:crm@localhost:5432/veent_crm"

# Better Auth (magic link via Resend) — STUB in v0
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:5173"

# Resend (magic-link + reminder email) — STUB in v0
RESEND_API_KEY=""
RESEND_FROM="Veent CRM <noreply@example.com>"

# Sentry (errors; sendDefaultPii:false) — STUB in v0
SENTRY_DSN=""

# Secret-authed endpoints (n8n reminder digest / future scraper ingest)
REMINDERS_ENDPOINT_SECRET=""
INGEST_SECRET=""
